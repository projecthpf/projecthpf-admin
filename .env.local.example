# ════════════════════════════════════════════════════════════════════
#  Project HPF Admin — environment variables
#
#  Copy to `.env.local` and fill with real values for local dev.
#  Production values live in the Flux app spec, never in the repo.
#
#  NEVER commit a real .env file. .gitignore covers .env.local but
#  double-check before any push.
# ════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Same Supabase project as members.projecthpf.org; admin tables
# live in their own schemas (admin_auth, admin_crm, admin_billing).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────
# Used as the magic-link redirect base. Must match the production
# URL exactly (Supabase Auth requires it on the redirect allowlist).
NEXT_PUBLIC_APP_URL=https://admin.projecthpf.org

# ── Resend (transactional email — invoices, receipts, notifications) ─
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=admin@projecthpf.org

# ── Stripe (donation processing + receipts) ───────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Plaid (bank account reconciliation) ───────────────────────
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENV=production

# ── Twilio (optional — SMS notifications) ─────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Google APIs (Drive for document storage, Calendar for events) ─
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...
GOOGLE_CALENDAR_ID=admin@projecthpf.org

# ── Anthropic (Claude API for OCR receipt parsing + AI features) ─
ANTHROPIC_API_KEY=sk-ant-...

# ── Cron security ─────────────────────────────────────────────
# Long random string. Generate: openssl rand -hex 32
# Cron endpoints (e.g. /api/daily-cron) reject requests without this header.
CRON_SECRET=CHANGE_ME_TO_RANDOM_HEX
